{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "functions": {
    "app/**/*.ts": {
      "maxDuration": 10
    },
    "app/**/*.tsx": {
      "maxDuration": 10
    }
  },
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://www.cornucopialocal.com"
  },
  "crons": [
    {
      "path": "/api/health/warmup",
      "schedule": "*/5 * * * *"
    }
  ]
}
